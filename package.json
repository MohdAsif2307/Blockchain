{
  "name": "dapp-data-marketplace",
  "version": "1.0.0",
  "description": "A decentralized data marketplace dApp with Ethereum smart contract, frontend, and optional backend.",
  "private": true,
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:local": "npx hardhat run scripts/deploy.js --network localhost",
    "start:backend": "node backend/server.js",
    "start:frontend": "npx http-server frontend -p 8080",
    "dev": "npx concurrently \"npm run start:backend\" \"npm run start:frontend\""
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "ethers": "^6.9.0",
    "hardhat": "^2.19.0",
    "http-server": "^14.1.1"
  }
}
